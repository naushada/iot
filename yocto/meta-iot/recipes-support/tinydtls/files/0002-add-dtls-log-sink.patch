Add dtls_set_log_sink() to mirror DTLS log lines to a host callback.

The iot LwM2M client (apps/src/main.cpp) installs a log sink so tinydtls
(DTLS) log output is routed into the host LogBuffer / UI. This is a local
addition carried in apps/3rdparty/tinydtls but absent from the legatoproject
fork this recipe fetches, which caused the iot binary link to fail with
"undefined reference to dtls_set_log_sink". Add it here so the Yocto-built
libtinydtls.a exposes the same symbol as the in-tree copy. Generated by
diffing apps/3rdparty/tinydtls against legatoproject SRCREV 9ae4f917.

Upstream-Status: Inappropriate [iot-local extension; mirrors apps/3rdparty/tinydtls]

--- a/dtls_debug.h
+++ b/dtls_debug.h
@@ -69,6 +69,13 @@
 /** Sets the log level to the specified value. */
 void dtls_set_log_level(log_t level);

+/*SWISTART*/
+/** Optional sink: when set, every dsrv_log() line is also delivered here
+ * (in addition to stderr/stdout) so the host app can route DTLS logs into
+ * its own log buffer / UI. `line` is the formatted message (no timestamp). */
+void dtls_set_log_sink(void (*sink)(int level, const char *line));
+/*SWISTOP*/
+
 /**
  * Writes the given text to \c stdout. The text is output only when \p
  * level is below or equal to the log level that set by
--- a/dtls_debug.c
+++ b/dtls_debug.c
@@ -210,7 +210,13 @@

 #endif /* NDEBUG */

-/*SWISTART*/
+/*SWISTART: log sink — defined UNCONDITIONALLY (outside HAVE_VPRINTF) so it
+  always links; the real dsrv_log that invokes it is guarded below. */
+static void (*g_dtls_log_sink)(int level, const char *line) = NULL;
+void dtls_set_log_sink(void (*sink)(int level, const char *line)) {
+  g_dtls_log_sink = sink;
+}
+/*SWISTOP*/
 #ifdef HAVE_VPRINTF
 #ifndef WITH_CONTIKI
 /*Macro-ed in dtls_debug.h in order to use the platform's standard debug output*/
@@ -236,6 +242,16 @@
   vfprintf(log_fd, format, ap);
   va_end(ap);
   fflush(log_fd);
+
+  /*SWISTART: mirror the formatted line to the host log sink (→ LogBuffer → UI). */
+  if (g_dtls_log_sink) {
+    char line[512];
+    va_start(ap, format);
+    vsnprintf(line, sizeof(line), format, ap);
+    va_end(ap);
+    g_dtls_log_sink((int)level, line);
+  }
+  /*SWISTOP*/
 }
 #endif /*__RTOS__*/
 #else /* WITH_CONTIKI */
