# stock fstab - you probably want to override this with a machine specific one

/dev/root            /                    auto       defaults              1  1
proc                 /proc                proc       defaults              0  0
devpts               /dev/pts             devpts     mode=0620,ptmxmode=0666,gid=5      0  0
tmpfs                /run                 tmpfs      mode=0755,nodev,nosuid,strictatime 0  0
tmpfs                /var/volatile        tmpfs      defaults              0  0

# uncomment this if your device has a SD/MMC/Transflash slot
#/dev/mmcblk0p1       /media/card          auto       defaults,sync,noauto  0  0

/dev/mmcblk0p1  /boot   vfat    defaults         0       0

# NOTE: the A/B data partition (p4, label "data") is NOT mounted from here on
# purpose — this fstab stays identical for the single-rootfs and A/B images. It
# is mounted at /var/lib/private by the shipped `var-lib-private.mount` systemd
# unit (recipes-iot/lwm2m), which self-skips (ConditionPathExists) on the
# single-rootfs image that has no such partition. That persists iot-ds's
# DynamicUser StateDirectory state (data_store.lua = wifi.networks, PSKs, …)
# across a RAUC A/B bank swap. It is /var/lib/private, NEVER /var/lib/iot: a
# mount at the latter collides with StateDirectory=iot and crash-loops iot-ds
# (exit 238/STATE_DIRECTORY, HW-confirmed). See apps/docs/tdd-ab-image-ota.md.
