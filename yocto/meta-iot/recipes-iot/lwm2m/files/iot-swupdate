#!/bin/sh
# iot-swupdate — install staged IPK(s) and migrate, then restart or reboot.
#
# Triggered by iot-swupdate.path (systemd inotify on /run/iot/update/update).
# Runs as root, oneshot. Flow (see apps/docs/tdd-yocto-swupdate.md):
#   1. lock          serialize concurrent activations
#   2. snapshot      move *.ipk + update.meta to a private work dir; remove the
#                    trigger (re-arms the .path unit, prevents a re-trigger loop)
#   3. install       opkg install the staged .ipk(s)
#   4. migrate (§11) restart ds-server (loads new schema) then run any pending
#                    /usr/share/iot/migrations, gated by iot.config.version
#   5. finish        reboot if a base/kernel/boot package landed (or reboot=
#                    override) else daemon-reload + try-restart the iot daemons
#
#   State:  0 idle, 3 updating          Result: 1 success, 9 install/migration error

set -u

# Survive opkg replacing this very script mid-run: re-exec from a tmpfs copy.
# (/run is wiped on reboot, so the copy never lingers.)
if [ "${IOT_SWUPDATE_REEXEC:-}" != "1" ]; then
    mkdir -p /run/iot/update 2>/dev/null || true
    # Never leave the spool 0755 root:root (root umask on a fresh mkdir): that locks
    # out the unprivileged group-iot lwm2m client from writing stage.req for the
    # NEXT cloud OTA (errno=13). Restore the tmpfiles mode/group. See iot-ota-stage.
    chgrp iot /run/iot/update 2>/dev/null || true
    chmod 2775 /run/iot/update 2>/dev/null || true
    _self="/run/iot/update/.self.$$"
    if cp "$0" "$_self" 2>/dev/null; then
        IOT_SWUPDATE_REEXEC=1 exec sh "$_self" "$@"
    fi
fi

SOCK="/run/iot/data_store.sock"
DSCLI="ds-cli --socket=${SOCK}"
SPOOL="/run/iot/update"
MIGDIR="/usr/share/iot/migrations"
LOG="$SPOOL/last.log"

set_state()   { $DSCLI set iot.update.state   "$1" >/dev/null 2>&1 || true; }
set_result()  { $DSCLI set iot.update.result  "$1" >/dev/null 2>&1 || true; }
set_version() { $DSCLI set iot.update.version "\"$1\"" >/dev/null 2>&1 || true; }
# Strip quotes/backslashes — the value rides inside a quoted JSON string and a
# raw opkg/rauc error line with `"` would break the parse (reason silently lost).
set_reason()  { $DSCLI set iot.update.reason  "\"$(printf '%s' "$1" | tr -d '"\\')\"" >/dev/null 2>&1 || true; }
log() { logger -t iot-swupdate "$*" 2>/dev/null; echo "iot-swupdate: $*"; }

# Parse "major.minor.patch" (ignoring any +build / -pre suffix) into one
# comparable integer; non-numeric fields count as 0. Mirrors the cloud-side
# semv() in apps/src/main.cpp so both downgrade gates agree.
semv() {
    v="${1%%+*}"; v="${v%%-*}"
    oIFS="$IFS"; IFS=.; set -- $v; IFS="$oIFS"
    a="${1:-0}"; b="${2:-0}"; c="${3:-0}"
    case "$a" in ''|*[!0-9]*) a=0 ;; esac
    case "$b" in ''|*[!0-9]*) b=0 ;; esac
    case "$c" in ''|*[!0-9]*) c=0 ;; esac
    echo $(( a * 1000000 + b * 1000 + c ))
}

# Wait for ds-server to answer after a (re)start; mirrors the compose healthcheck.
ds_wait() {
    i=0
    while [ "$i" -lt 30 ]; do
        $DSCLI get log.version >/dev/null 2>&1 && return 0
        i=$((i + 1)); sleep 1
    done
    return 1
}

# §11 — config/schema migration. Restart ds so it loads the (possibly updated)
# schemas, then run ordered, idempotent migrations newer than iot.config.version.
run_migrations() {
    systemctl restart iot-ds.service >/dev/null 2>&1 || true
    ds_wait || { log "ds-server did not come back after restart"; return 1; }

    [ -d "$MIGDIR" ] || return 0
    cur="$($DSCLI get iot.config.version 2>/dev/null | sed 's/^iot\.config\.version=//')"
    case "$cur" in ''|*[!0-9]*) cur=0 ;; esac

    for m in "$MIGDIR"/[0-9]*.sh; do
        [ -e "$m" ] || continue
        base="$(basename "$m")"
        num="${base%%-*}"
        case "$num" in ''|*[!0-9]*) continue ;; esac
        if [ "$((10#$num))" -gt "$((10#$cur))" ]; then
            log "migration $base"
            if sh "$m" >>"$LOG" 2>&1; then
                $DSCLI set iot.config.version "$((10#$num))" >/dev/null 2>&1 || true
            else
                log "migration $base FAILED"
                return 1
            fi
        fi
    done
    return 0
}

# ── 1. serialize ───────────────────────────────────────────────────
exec 9>"$SPOOL/.lock" 2>/dev/null || true
if command -v flock >/dev/null 2>&1; then
    flock -n 9 || { log "another run in progress; exit"; exit 0; }
fi

# ── 2. snapshot + re-arm ───────────────────────────────────────────
WORK="$SPOOL/.work-$$"
mkdir -p "$WORK"

# A drag-and-drop bundle (.tar/.tar.gz/.tgz) lands here UN-extracted: the
# device-ui /api/v1/update/upload path drops the tarball and trips us directly,
# bypassing iot-ota-stage (which is what normally expands a bundle for the
# cloud/URL push). Expand any bundle in the spool into its .ipks so the *.ipk
# snapshot below installs them all. Compression is detected by CONTENT (gzip -t),
# not the extension: macOS auto-decompresses a downloaded .tar.gz to a plain
# .tar, so the name is unreliable. busybox-safe: gzip -dc | tar (not tar -z). On
# the cloud/URL path iot-ota-stage already extracted + removed the tarball, so
# this is a no-op.
for b in "$SPOOL"/*.tar "$SPOOL"/*.tar.gz "$SPOOL"/*.tgz; do
    [ -e "$b" ] || continue
    if gzip -t "$b" 2>/dev/null; then
        ok=$( ( cd "$SPOOL" && gzip -dc "$b" | tar -xf - ) 2>/dev/null && echo 1 )
    else
        ok=$( ( cd "$SPOOL" && tar -xf "$b" ) 2>/dev/null && echo 1 )
    fi
    if [ "$ok" = 1 ]; then
        log "expanded bundle $(basename "$b")"
    else
        log "bundle extract FAILED: $(basename "$b")"
    fi
    rm -f "$b"
done

# Snapshot the installable artifacts. .ipk → opkg path; .raucb → A/B rauc path
# (handled in §3). Either kind counts as "staged" so a raucb-only drop isn't
# mistaken for an empty trigger.
moved=0
for f in "$SPOOL"/*.ipk "$SPOOL"/*.raucb; do
    [ -e "$f" ] || continue
    mv "$f" "$WORK/" && moved=1
done
[ -e "$SPOOL/update.meta" ] && mv "$SPOOL/update.meta" "$WORK/" 2>/dev/null || true
rm -f "$SPOOL/update"   # re-arm the .path unit

if [ "$moved" = 0 ]; then
    log "trigger but no .ipk/.raucb staged; nothing to do"
    rm -rf "$WORK"
    exit 0
fi

# Read metadata sidecar (version / reboot policy).
VER=""; REBOOT="auto"
if [ -f "$WORK/update.meta" ]; then
    while IFS='=' read -r k v; do
        case "$k" in version) VER="$v" ;; reboot) REBOOT="$v" ;; esac
    done < "$WORK/update.meta"
fi

# ── downgrade guard ────────────────────────────────────────────────
# Refuse a bundle whose semver is OLDER than what's running. The cloud has
# its own push gate, but it fails closed only once it has read the device's
# /3/0/3 version — a push ~2 s after registration (before that read) once
# offered a 1.2.0 bundle to this 1.3.0 unit, and `opkg install` then died on
# the cross-version dependency conflict and left this service failed. This is
# the last line of defense. Same-semver re-installs (a newer +git build of the
# same release) are allowed; only a strictly-lower semver is rejected.
if [ -n "$VER" ]; then
    CUR="$($DSCLI get iot.version 2>/dev/null | sed 's/^iot\.version=//')"
    if [ -n "$CUR" ] && [ "$(semv "$VER")" -lt "$(semv "$CUR")" ]; then
        log "refusing downgrade: offered=$VER < installed=$CUR; skipping"
        set_version "$CUR"   # report what is actually installed, not the offer
        set_reason "downgrade refused (offered $VER < installed $CUR)"
        set_result 10        # 10 = skipped (offered not newer) — NOT an error
        set_state 0
        rm -rf "$WORK"
        rm -f "/run/iot/update/.self.$$"
        exit 0
    fi
fi

# ── 3. install ─────────────────────────────────────────────────────
set_state 3   # updating

# A/B image bundle (.raucb, Phase 2): rauc writes the *inactive* bank, then we
# reboot into it; a health check confirms or the bootloader rolls back to the
# previous bank. Atomic + power-fail-safe (unlike the in-place opkg path below).
# See apps/docs/tdd-ab-image-ota.md. Requires the RAUC-enabled image.
RAUCB="$(ls "$WORK"/*.raucb 2>/dev/null | head -1)"
if [ -n "$RAUCB" ]; then
    if ! command -v rauc >/dev/null 2>&1; then
        log "rauc not installed — cannot apply $(basename "$RAUCB") (needs the A/B image)"
        set_reason "rauc not installed (needs the A/B image)"
        set_result 9; set_state 0; rm -rf "$WORK"; exit 1
    fi
    log "rauc install $RAUCB"
    if ! rauc install "$RAUCB" >"$LOG" 2>&1; then
        log "$(tail -5 "$LOG" 2>/dev/null)"
        set_reason "rauc install failed: $(tail -1 "$LOG" 2>/dev/null | cut -c1-160)"
        set_result 9; set_state 0; rm -rf "$WORK"; exit 1
    fi
    [ -n "$VER" ] && set_version "$VER"
    set_reason ""
    set_result 1; set_state 0
    rm -rf "$WORK"
    log "A/B bundle staged to the inactive bank; rebooting to activate"
    systemctl reboot
    exit 0
fi

log "opkg install $WORK/*.ipk"
if ! opkg install --force-reinstall --force-downgrade "$WORK"/*.ipk >"$LOG" 2>&1; then
    log "$(tail -5 "$LOG" 2>/dev/null)"
    set_reason "opkg install failed: $(tail -1 "$LOG" 2>/dev/null | cut -c1-160)"
    set_result 9; set_state 0
    rm -rf "$WORK"
    exit 1
fi

# Installed version: meta wins, else parse the opkg log.
[ -z "$VER" ] && VER="$(awk '/Installing/{v=$3} END{gsub(/[()]/,"",v); print v}' "$LOG")"
[ -n "$VER" ] && set_version "$VER"

# Capture installed/upgraded package names for the reboot decision.
INSTALLED="$(awk '/Installing|Upgrading/{print $2}' "$LOG" 2>/dev/null)"

# ── 4. config/schema migration (§11) ───────────────────────────────
log "running config migrations"
if ! run_migrations; then
    log "migration failed; NOT restarting app daemons (operator intervention)"
    set_reason "config/schema migration failed"
    set_result 9; set_state 0
    rm -rf "$WORK"
    exit 1
fi

# ── success ────────────────────────────────────────────────────────
set_reason ""
set_result 1; set_state 0
log "update applied (version=${VER:-unknown})"

# ── 5. reboot-vs-restart decision (§4) ─────────────────────────────
need_reboot=0
case "$REBOOT" in
    always) need_reboot=1 ;;
    never)  need_reboot=0 ;;
    *)      # auto
        [ -e /run/reboot-required ] && need_reboot=1
        for p in $INSTALLED; do
            case "$p" in
                kernel*|linux-*|*-image-*|u-boot*|*-bootloader|base-files|systemd)
                    need_reboot=1 ;;
            esac
        done
        ;;
esac

rm -rf "$WORK"
rm -f "/run/iot/update/.self.$$"

if [ "$need_reboot" = 1 ]; then
    log "reboot required; rebooting"
    systemctl reboot
else
    log "restarting iot daemons"
    systemctl daemon-reload >/dev/null 2>&1 || true

    # Enable any unit this update NEWLY shipped. opkg drops the .service file but
    # never enables it: SYSTEMD_AUTO_ENABLE / 90-iot.preset only run at image
    # build + first boot. So a daemon introduced BY an OTA (iot-smsctld was the
    # first) installed fine and then sat there `disabled`, invisible, until
    # someone reflashed. Consult the shipped preset policy — the same file
    # first-boot uses — and enable only what it says to enable, only for units
    # this update actually installed. An operator's deliberate `systemctl
    # disable` of a pre-existing unit is therefore never overridden.
    PRESET=/lib/systemd/system-preset/90-iot.preset
    [ -f "$PRESET" ] || PRESET=/usr/lib/systemd/system-preset/90-iot.preset
    for pkg in $INSTALLED; do
        for f in $(opkg files "$pkg" 2>/dev/null | grep -E '/systemd/system/iot-[^/]+\.(service|path)$'); do
            unit="$(basename "$f")"
            [ -f "$PRESET" ] || continue
            grep -q "^enable[[:space:]]\+$unit\$" "$PRESET" || continue
            state="$(systemctl is-enabled "$unit" 2>/dev/null)"
            if [ "$state" = "disabled" ]; then
                log "enabling newly shipped unit $unit (preset policy)"
                systemctl enable "$unit" >/dev/null 2>&1 || true
            fi
        done
    done

    # Restart EVERY long-running iot daemon this image ships — derived from the
    # unit files, not a hand-maintained list. The old code hardcoded five units
    # and used `try-restart`, which is a no-op on an inactive unit. Two
    # consequences, both seen on HW: (a) cellular/containers/sensors/ddns/mqtt/
    # vehicle/smsctl were never in the list, so after an OTA they kept running
    # the OLD binary until the next reboot; (b) a unit that happened to be
    # inactive (cellular-client, skipped by its old ConditionPathExistsGlob) was
    # never started, so the new code never ran at all — which is exactly how a
    # phantom "connected" modem survived an update that was supposed to fix it.
    #
    # try-restart if it is running; start it if it is enabled but stopped.
    # iot-ds is excluded: the migration step above already restarted it, and it
    # is the store every other daemon depends on.
    for f in /lib/systemd/system/iot-*.service /usr/lib/systemd/system/iot-*.service; do
        [ -f "$f" ] || continue
        unit="$(basename "$f")"
        case "$unit" in
            iot-ds.service) continue ;;                      # handled by migrate
        esac
        grep -q '^\[Install\]' "$f" || continue            # path/oneshot-activated helper
        grep -q '^Type=oneshot' "$f" && continue             # not a daemon
        systemctl is-enabled "$unit" >/dev/null 2>&1 || continue
        if systemctl is-active --quiet "$unit"; then
            systemctl try-restart "$unit" >/dev/null 2>&1 || true
        else
            log "starting $unit (was stopped; new code needs it up)"
            systemctl start "$unit" >/dev/null 2>&1 || true
        fi
    done
fi
exit 0
