#!/bin/sh
# iot-swupdate — install staged IPK(s) and migrate, then restart or reboot.
#
# Triggered by iot-swupdate.path (systemd inotify on /run/iot/update/update).
# Runs as root, oneshot. Flow (see apps/docs/tdd-yocto-swupdate.md):
#   1. lock          serialize concurrent activations
#   2. snapshot      move *.ipk + update.meta to a private work dir; remove the
#                    trigger (re-arms the .path unit, prevents a re-trigger loop)
#   3. install       opkg install the staged .ipk(s)
#   4. migrate (§11) restart ds-server (loads new schema) then run any pending
#                    /usr/share/iot/migrations, gated by iot.config.version
#   5. finish        reboot if a base/kernel/boot package landed (or reboot=
#                    override) else daemon-reload + try-restart the iot daemons
#
#   State:  0 idle, 3 updating          Result: 1 success, 9 install/migration error

set -u

# Survive opkg replacing this very script mid-run: re-exec from a tmpfs copy.
# (/run is wiped on reboot, so the copy never lingers.)
if [ "${IOT_SWUPDATE_REEXEC:-}" != "1" ]; then
    mkdir -p /run/iot/update 2>/dev/null || true
    _self="/run/iot/update/.self.$$"
    if cp "$0" "$_self" 2>/dev/null; then
        IOT_SWUPDATE_REEXEC=1 exec sh "$_self" "$@"
    fi
fi

SOCK="/run/iot/data_store.sock"
DSCLI="ds-cli --socket=${SOCK}"
SPOOL="/run/iot/update"
MIGDIR="/usr/share/iot/migrations"
LOG="$SPOOL/last.log"

set_state()   { $DSCLI set iot.update.state   "$1" >/dev/null 2>&1 || true; }
set_result()  { $DSCLI set iot.update.result  "$1" >/dev/null 2>&1 || true; }
set_version() { $DSCLI set iot.update.version "\"$1\"" >/dev/null 2>&1 || true; }
log() { logger -t iot-swupdate "$*" 2>/dev/null; echo "iot-swupdate: $*"; }

# Wait for ds-server to answer after a (re)start; mirrors the compose healthcheck.
ds_wait() {
    i=0
    while [ "$i" -lt 30 ]; do
        $DSCLI get log.version >/dev/null 2>&1 && return 0
        i=$((i + 1)); sleep 1
    done
    return 1
}

# §11 — config/schema migration. Restart ds so it loads the (possibly updated)
# schemas, then run ordered, idempotent migrations newer than iot.config.version.
run_migrations() {
    systemctl restart iot-ds.service >/dev/null 2>&1 || true
    ds_wait || { log "ds-server did not come back after restart"; return 1; }

    [ -d "$MIGDIR" ] || return 0
    cur="$($DSCLI get iot.config.version 2>/dev/null | sed 's/^iot\.config\.version=//')"
    case "$cur" in ''|*[!0-9]*) cur=0 ;; esac

    for m in "$MIGDIR"/[0-9]*.sh; do
        [ -e "$m" ] || continue
        base="$(basename "$m")"
        num="${base%%-*}"
        case "$num" in ''|*[!0-9]*) continue ;; esac
        if [ "$((10#$num))" -gt "$((10#$cur))" ]; then
            log "migration $base"
            if sh "$m" >>"$LOG" 2>&1; then
                $DSCLI set iot.config.version "$((10#$num))" >/dev/null 2>&1 || true
            else
                log "migration $base FAILED"
                return 1
            fi
        fi
    done
    return 0
}

# ── 1. serialize ───────────────────────────────────────────────────
exec 9>"$SPOOL/.lock" 2>/dev/null || true
if command -v flock >/dev/null 2>&1; then
    flock -n 9 || { log "another run in progress; exit"; exit 0; }
fi

# ── 2. snapshot + re-arm ───────────────────────────────────────────
WORK="$SPOOL/.work-$$"
mkdir -p "$WORK"
moved=0
for f in "$SPOOL"/*.ipk; do
    [ -e "$f" ] || continue
    mv "$f" "$WORK/" && moved=1
done
[ -e "$SPOOL/update.meta" ] && mv "$SPOOL/update.meta" "$WORK/" 2>/dev/null || true
rm -f "$SPOOL/update"   # re-arm the .path unit

if [ "$moved" = 0 ]; then
    log "trigger but no .ipk staged; nothing to do"
    rm -rf "$WORK"
    exit 0
fi

# Read metadata sidecar (version / reboot policy).
VER=""; REBOOT="auto"
if [ -f "$WORK/update.meta" ]; then
    while IFS='=' read -r k v; do
        case "$k" in version) VER="$v" ;; reboot) REBOOT="$v" ;; esac
    done < "$WORK/update.meta"
fi

# ── 3. install ─────────────────────────────────────────────────────
set_state 3   # updating
log "opkg install $WORK/*.ipk"
if ! opkg install --force-reinstall --force-downgrade "$WORK"/*.ipk >"$LOG" 2>&1; then
    log "$(tail -5 "$LOG" 2>/dev/null)"
    set_result 9; set_state 0
    rm -rf "$WORK"
    exit 1
fi

# Installed version: meta wins, else parse the opkg log.
[ -z "$VER" ] && VER="$(awk '/Installing/{v=$3} END{gsub(/[()]/,"",v); print v}' "$LOG")"
[ -n "$VER" ] && set_version "$VER"

# Capture installed/upgraded package names for the reboot decision.
INSTALLED="$(awk '/Installing|Upgrading/{print $2}' "$LOG" 2>/dev/null)"

# ── 4. config/schema migration (§11) ───────────────────────────────
log "running config migrations"
if ! run_migrations; then
    log "migration failed; NOT restarting app daemons (operator intervention)"
    set_result 9; set_state 0
    rm -rf "$WORK"
    exit 1
fi

# ── success ────────────────────────────────────────────────────────
set_result 1; set_state 0
log "update applied (version=${VER:-unknown})"

# ── 5. reboot-vs-restart decision (§4) ─────────────────────────────
need_reboot=0
case "$REBOOT" in
    always) need_reboot=1 ;;
    never)  need_reboot=0 ;;
    *)      # auto
        [ -e /run/reboot-required ] && need_reboot=1
        for p in $INSTALLED; do
            case "$p" in
                kernel*|linux-*|*-image-*|u-boot*|*-bootloader|base-files|systemd)
                    need_reboot=1 ;;
            esac
        done
        ;;
esac

rm -rf "$WORK"
rm -f "/run/iot/update/.self.$$"

if [ "$need_reboot" = 1 ]; then
    log "reboot required; rebooting"
    systemctl reboot
else
    log "restarting iot daemons"
    systemctl daemon-reload >/dev/null 2>&1 || true
    for unit in iot-lwm2m-client iot-httpd iot-openvpn-client iot-net-router iot-wifi-client; do
        systemctl try-restart "${unit}.service" >/dev/null 2>&1 || true
    done
fi
exit 0
