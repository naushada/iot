#!/bin/sh
# iot-ota-apply <url> — OTA .ipk apply for the LwM2M Object-5 firmware update.
#
# Runs DETACHED (a `systemd-run --unit=iot-ota-apply` transient unit) so it
# survives opkg replacing the running `lwm2m` binary and the subsequent unit
# restart. Pulls the .ipk from the cloud firmware feed over the VPN tunnel,
# verifies its sha256, installs via opkg, then restarts the affected units.
#
# Progress is written to ds (iot.update.state/result/version) so device-ui and
# the relaunched lwm2m client (which mirrors them onto Object 5 /5/0/3,/5/0/5,
# /5/0/7) reflect the outcome after restart.
#
# URL may carry ?sha256=<hex>&version=<v> query params.
#
#   State:  0 idle, 1 downloading, 2 downloaded, 3 updating
#   Result: 0 initial, 1 success, 5 integrity, 8 uri error, 9 install error

set -u

URL="${1:-}"
SOCK="/run/iot/data_store.sock"
DSCLI="ds-cli --socket=${SOCK}"
CACHE="/var/cache/iot"
IPK="${CACHE}/fw.ipk"

set_state()   { $DSCLI set iot.update.state  "$1" >/dev/null 2>&1 || true; }
set_result()  { $DSCLI set iot.update.result "$1" >/dev/null 2>&1 || true; }
set_version() { $DSCLI set iot.update.version "\"$1\"" >/dev/null 2>&1 || true; }
log() { logger -t iot-ota-apply "$*" 2>/dev/null; echo "iot-ota-apply: $*"; }

fail() { log "FAILED ($1): $2"; set_result "$1"; set_state 0; exit 1; }

[ -n "$URL" ] || fail 8 "no URL"

# Parse optional query params (sha256, version).
QUERY="${URL#*\?}"; [ "$QUERY" = "$URL" ] && QUERY=""
SHA=""; VER=""
for kv in $(echo "$QUERY" | tr '&' ' '); do
    case "$kv" in
        sha256=*)  SHA="${kv#sha256=}" ;;
        version=*) VER="${kv#version=}" ;;
    esac
done

mkdir -p "$CACHE"
set_state 1   # downloading
log "downloading $URL"
if command -v wget >/dev/null 2>&1; then
    wget --no-check-certificate -q -O "$IPK" "$URL" || fail 8 "download failed"
elif command -v curl >/dev/null 2>&1; then
    curl -ksSL -o "$IPK" "$URL" || fail 8 "download failed"
else
    fail 9 "no wget/curl on device"
fi
[ -s "$IPK" ] || fail 8 "empty download"

set_state 2   # downloaded
if [ -n "$SHA" ]; then
    GOT="$(sha256sum "$IPK" 2>/dev/null | awk '{print $1}')"
    if [ "$GOT" != "$SHA" ]; then
        fail 5 "sha256 mismatch (want $SHA got $GOT)"
    fi
    log "sha256 verified"
fi

set_state 3   # updating
log "opkg install $IPK"
if ! opkg install --force-reinstall --force-downgrade "$IPK" >/tmp/iot-ota-opkg.log 2>&1; then
    log "$(tail -5 /tmp/iot-ota-opkg.log)"
    fail 9 "opkg install failed"
fi

# Derive installed version (query param wins; else from opkg install output).
if [ -z "$VER" ]; then
    VER="$(awk '/Installing/{v=$3} END{gsub(/[()]/,"",v); print v}' /tmp/iot-ota-opkg.log)"
fi
[ -n "$VER" ] && set_version "$VER"
set_result 1
set_state 0
log "update applied (version=${VER:-unknown}); restarting units"

# Restart the affected units. try-restart is a no-op for units not present.
for unit in iot-lwm2m-client iot-httpd iot-openvpn-client iot-net-router iot-wifi-client; do
    systemctl try-restart "${unit}.service" >/dev/null 2>&1 || true
done
exit 0
