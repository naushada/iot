[Unit]
Description=IoT HTTP REST API server (iot-httpd, fronts ds-server over /run/iot/data_store.sock)
Documentation=https://github.com/naushada/iot
After=network-online.target iot-ds.service
Wants=network-online.target
Requires=iot-ds.service
StartLimitBurst=5
StartLimitIntervalSec=60s

[Service]
Type=simple
EnvironmentFile=-/etc/iot/httpd.env
ExecStart=/usr/bin/iot-httpd $HTTPD_ARGS

DynamicUser=yes
# Join the `iot` group so the dynamic user can write the drag-and-drop OTA spool
# (/run/iot/update, 0775 root:iot) — iot-httpd drops the uploaded .ipk + trigger,
# root iot-swupdate installs it. (Also the group that owns the ds socket.)
# /run/iot itself is created by tmpfiles.d/iot.conf, not RuntimeDirectory=iot:
# a RuntimeDirectory= here is removed on stop/restart, taking the shared dir
# (ds socket + OTA spool) with it.
SupplementaryGroups=iot

# Lets the dynamic user bind :80/:443 when http.listen.port is set low.
AmbientCapabilities=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_BIND_SERVICE

# Restart=always (not on-failure) so the daemon comes back after a CLEAN exit
# too: iot-httpd self-restarts to apply an http.workers change (the pool is
# sized at startup and can't be hot-resized). `systemctl stop` is an intentional
# stop and is NOT restarted; the StartLimit above still guards against flapping.
Restart=always
RestartSec=2s

StandardOutput=journal
StandardError=journal

NoNewPrivileges=yes
PrivateTmp=yes
ProtectKernelTunables=yes
ProtectControlGroups=yes
RestrictRealtime=yes

[Install]
WantedBy=multi-user.target
