# EnvironmentFile for iot-httpd.service.
#
# HTTPD_ARGS is the literal argv tail passed to /usr/bin/iot-httpd.
# Recognised keys (CLI > data store > built-in defaults):
#   ds-socket=<path>   ds-server unix socket  (default /var/run/iot/data_store.sock)
#   http-ip=<ip>       listen address         (default 0.0.0.0)
#   http-port=<N>      listen port            (default 8080)
#
# The http.listen.* keys in ds-server override ip/port at runtime and
# are hot-reloadable via ds-cli — see /etc/iot/ds-schemas/http.lua:
#   ds-cli set http.listen.ip   '"0.0.0.0"'
#   ds-cli set http.listen.port '8080'
#
# Operator workflow (bare metal):
#   systemctl enable --now iot-httpd.service
#   journalctl -u iot-httpd.service -f

HTTPD_ARGS="ds-socket=/run/iot/data_store.sock"
